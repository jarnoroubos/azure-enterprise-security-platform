{
  "properties": {
    "displayName": "Deny Public IP Addresses",
    "description": "This policy denies the creation of public IP addresses to reduce exposure to the internet.",
    "mode": "All",
    "metadata": {
      "category": "Network",
      "version": "1.0.0"
    },
    "policyRule": {
      "if": {
        "field": "type",
        "equals": "Microsoft.Network/publicIPAddresses"
      },
      "then": {
        "effect": "deny"
      }
    }
  }
}
